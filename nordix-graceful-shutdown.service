[Unit]
Description=Nordix Graceful Shutdown Daemon
Requires=nordix-graceful-shutdown.socket
After=zfs.target

[Service]
Type=simple
ExecStart=/usr/lib/nordix/nordix-graceful-shutdown
Restart=on-failure
RestartSec=2

# Run as root to perform unmounts and poweroff
User=root

# Keep running after user logout
KillMode=process

# Give enough time for the full shutdown sequence
TimeoutStopSec=300

[Install]
WantedBy=multi-user.target
